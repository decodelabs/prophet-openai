{
    "name": "decodelabs/prophet-openai",
    "description": "OpenAI Responses adapter for DecodeLabs Prophet",
    "type": "library",
    "keywords": [ ],
    "license": "MIT",
    "authors": [
        {
            "name": "Tom Wright",
            "email": "tom@inflatablecookie.com"
        }
    ],
    "require": {
        "php": "^8.4",

        "decodelabs/exceptional": "^0.6.3",
        "decodelabs/prophet": "^0.6",

        "openai-php/client": "^0.19"
    },
    "require-dev": {
        "decodelabs/chorus": ">0",
        "decodelabs/phpstan-decodelabs": "^0.7",

        "guzzlehttp/guzzle": "^7.9.3",
        "guzzlehttp/psr7": "^2.7.1",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "DecodeLabs\\Prophet\\Platform\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DecodeLabs\\Prophet\\Platform\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-develop": "0.4.x-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    }
}
